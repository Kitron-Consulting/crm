        email = flags.get("email", "")
        if validate_email(email):
            print(f"{RED}Invalid email: {email}{RESET}")
            return
        source = flags.get("source", "cold")
        if source not in sources:
            print(f"{RED}Invalid source: {source}. Use: {', '.join(sources)}{RESET}")
            return
