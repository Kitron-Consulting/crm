    else:
        matches = removed

    if not matches:
        print(f"No removed contacts matching '{args[0]}'")
        return

    def format_removed(c):
        return f"{c['name']} ({c['company']}) [removed {c.get('removed_at', '?')}]"

    if len(matches) == 1:
        c = matches[0]
    else:
        c = pick_one(matches, prompt="Restore which contact?", format_fn=format_removed)

    if not c:
        return

