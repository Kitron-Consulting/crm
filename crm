#!/usr/bin/env python3
"""
crm — lightweight CLI pipeline tracker

USAGE
  crm <command> [arguments]

COMMANDS
  list [STAGE]           List all contacts grouped by stage
                         Optional: filter by stage (e.g., crm list meeting)

  due [DAYS]             Show what needs action (default: next 7 days)
  
  show [QUERY]           Show contact details + full history
                         Without QUERY: interactive picker
  
  note [QUERY] [TEXT]    Add a timestamped note
                         Without args: interactive
  
  stage [QUERY] [STAGE]  Move contact to new stage
                         Without args: interactive
  
  next [QUERY] [ACTION] [DATE]
                         Set next action and due date
                         DATE can be YYYY-MM-DD or relative like +7d
  
  edit [QUERY]           Open contact in $EDITOR (default: nano)
  
  add contact             Add new contact (interactive)
  add stage [NAME]       Add a stage

  rm contact [QUERY]     Remove a contact (soft delete)
  rm stage [NAME]        Remove a stage (if empty)

  restore [QUERY]        Restore a removed contact

  search TERM            Search across all contacts and notes
  
  stages                 List stages

  config [KEY] [VALUE]   Get/set config (e.g., timezone)

EXAMPLES
  crm due                What's due this week?
  crm due 14             What's due in the next 2 weeks?
  crm list               Show full pipeline
  crm list meeting       Show only meetings
  crm show               Pick contact interactively
  crm show mekitec       Show Mekitec contact details
  crm note               Pick contact, then type note
  crm note mekitec "Called, no answer"
  crm stage              Pick contact and stage interactively
  crm stage mekitec responded
  crm next mekitec "Send proposal" +3d
  crm edit               Pick contact to edit

STAGES
  cold → contacted → responded → meeting → proposal → won
                                                    ↘ lost
                                                    ↘ dormant

FILES
  Data stored in crm_data.json (same folder as this script)
"""

import json
import sys
import os
import re
from datetime import datetime, timedelta, timezone
from pathlib import Path

# Data file location — same directory as script
DATA_FILE = Path(__file__).parent / "crm_data.json"

DEFAULT_STAGES = ["cold", "contacted", "responded", "meeting", "proposal", "won", "lost", "dormant"]
CURRENT_VERSION = 2

# --- Migrations ---
# Key = target version. Only add an entry when the schema actually changes.

def migrate_to_1(data):
    """Initial schema: ensure config, stages, removed exist. Move top-level timezone to config."""
    if "config" not in data:
        data["config"] = {}
    if "timezone" in data:
        data["config"]["timezone"] = data.pop("timezone")
    if "removed" not in data:
        data["removed"] = []
    if "last_contact" in data:
        del data["last_contact"]
    for c in data.get("contacts", []):
        c.pop("last_contact", None)

def migrate_to_2(data):
    """Move stages from top-level into config."""
    if "stages" in data:
        data["config"]["stages"] = data.pop("stages")
    if "stages" not in data["config"]:
        data["config"]["stages"] = DEFAULT_STAGES[:]

MIGRATIONS = {
    1: migrate_to_1,
    2: migrate_to_2,
}

def get_stages(data):
    return data["config"]["stages"]

def load_data():
    if DATA_FILE.exists():
        with open(DATA_FILE, "r", encoding="utf-8") as f:
            data = json.load(f)
    else:
        data = {"contacts": []}

    version = data.get("version", 0)
    if version < CURRENT_VERSION:
        while version < CURRENT_VERSION:
            version += 1
            if version in MIGRATIONS:
                MIGRATIONS[version](data)
        data["version"] = CURRENT_VERSION
        save_data(data)

    return data

def _parse_tz(tz_str):
    """Parse a timezone string like 'UTC+03:00' or 'UTC-05:00' into a timezone object."""
    if tz_str == "UTC":
        return timezone.utc
    sign = 1 if "+" in tz_str else -1
    parts = tz_str.split("+")[-1].split("-")[-1]
    h, m = parts.split(":")
    return timezone(timedelta(hours=sign * int(h), minutes=sign * int(m)))

def get_tz(data):
    cfg = data["config"]
    tz_str = cfg.get("timezone")
    if not tz_str:
        local_tz = datetime.now().astimezone().tzinfo
        offset = local_tz.utcoffset(datetime.now())
        total = int(offset.total_seconds())
        sign = "+" if total >= 0 else "-"
        total = abs(total)
        hours, remainder = divmod(total, 3600)
        minutes = remainder // 60
        tz_str = f"UTC{sign}{hours:02d}:{minutes:02d}"
        cfg["timezone"] = tz_str
        data["config"] = cfg
        save_data(data)
        print(f"Timezone set to {tz_str}. Change with: crm config timezone UTC+XX:XX")
    return _parse_tz(tz_str)

def save_data(data):
    with open(DATA_FILE, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=2, ensure_ascii=False)

def pick_one(items, prompt="Select", format_fn=None):
    """Interactive picker. Returns selected item or None if cancelled."""
    if not items:
        print("No items to select from.")
        return None
    
    if format_fn is None:
        format_fn = str
    
    print(f"\n{prompt}:")
    for i, item in enumerate(items, 1):
        print(f"  {i}. {format_fn(item)}")
    print(f"  0. Cancel")
    
    try:
        choice = input("\n> ").strip()
        if not choice or choice == "0":
            return None
        idx = int(choice) - 1
        if 0 <= idx < len(items):
            return items[idx]
        print("Invalid selection.")
        return None
    except (ValueError, EOFError, KeyboardInterrupt):
        print()
        return None

def format_contact_option(c):
    role = c.get('role', '')
    role_str = f" — {role}" if role else ""
    return f"{c['name']} ({c['company']}{role_str}) [{c['stage'].upper()}]"

def pick_contact_from_all(data, prompt="Select contact"):
    """Pick any contact interactively."""
    stages = get_stages(data)
    order = {s: i for i, s in enumerate(stages)}
    contacts = sorted(data["contacts"], key=lambda c: (order.get(c["stage"], 99), c["name"]))
    return pick_one(contacts, prompt=prompt, format_fn=format_contact_option)

def pick_contact_from_matches(matches):
    """Pick from search results."""
    if len(matches) == 1:
        return matches[0]
    return pick_one(matches, prompt="Multiple matches", format_fn=format_contact_option)

def find_contact(data, query):
    query = query.lower()
    matches = []
    for c in data["contacts"]:
        if query in c["name"].lower() or query in c["company"].lower() or query in c["email"].lower():
            matches.append(c)
    return matches

def get_contact(data, query=None, prompt="Select contact"):
    """Get a contact - by query if provided, or interactive picker."""
    if query:
        matches = find_contact(data, query)
        if not matches:
            print(f"No contacts matching '{query}'")
            return None
        return pick_contact_from_matches(matches)
    else:
        return pick_contact_from_all(data, prompt)

def parse_date(s, tz=None):
    if not s:
        return ""
    if s.startswith("+") and s.endswith("d"):
        days = int(s[1:-1])
        return (datetime.now(tz) + timedelta(days=days)).strftime("%Y-%m-%d")
    try:
        datetime.strptime(s, "%Y-%m-%d")
    except ValueError:
        print(f"Invalid date: {s}. Use YYYY-MM-DD or +Nd")
        return None
    return s

def format_contact_line(c):
    stage = c["stage"].upper()
    due = c.get("next_date", "")
    action = c.get("next_action", "")
    due_str = f" → {due}: {action}" if due and action else ""
    return f"  {c['name']} ({c['company']}) [{stage}]{due_str}"

def cmd_list(args):
    data = load_data()
    filter_stage = args[0].lower() if args else None
    
    contacts = data["contacts"]
    if filter_stage:
        contacts = [c for c in contacts if c["stage"].lower() == filter_stage]
    
    by_stage = {}
    for c in contacts:
        stage = c["stage"]
        if stage not in by_stage:
            by_stage[stage] = []
        by_stage[stage].append(c)
    
    for stage in get_stages(data):
        if stage in by_stage:
            print(f"\n{stage.upper()} ({len(by_stage[stage])})")
            for c in sorted(by_stage[stage], key=lambda x: x.get("next_date") or "z"):
                print(format_contact_line(c))
    print()

def cmd_show(args):
    data = load_data()
    c = get_contact(data, args[0] if args else None, "Show which contact?")
    if not c:
        return
    
    print(f"\n{'='*50}")
    print(f"{c['name']} — {c['company']}")
    print(f"{'='*50}")
    print(f"Email:   {c['email']}")
    print(f"Phone:   {c.get('phone', '')}")
    print(f"Role:    {c.get('role', '')}")
    print(f"Source:  {c.get('source', '')}")
    print(f"Stage:   {c['stage'].upper()}")
    print(f"Next:    {c.get('next_date', '')} — {c.get('next_action', '')}")
    print(f"\nNotes:")
    for note in c.get("notes", []):
        print(f"  [{note['date']}] {note['text']}")
    print()

def cmd_note(args):
    data = load_data()
    
    if args:
        c = get_contact(data, args[0], "Add note to which contact?")
        note_text = " ".join(args[1:]) if len(args) > 1 else None
    else:
        c = get_contact(data, None, "Add note to which contact?")
        note_text = None
    
    if not c:
        return
    
    if not note_text:
        note_text = input("Note: ").strip()
        if not note_text:
            print("Cancelled.")
            return
    
    stamp = datetime.now(get_tz(data)).strftime("%Y-%m-%d %H:%M")
    if "notes" not in c:
        c["notes"] = []
    c["notes"].insert(0, {"date": stamp, "text": note_text})

    save_data(data)
    print(f"Added note to {c['name']}")

def cmd_stage(args):
    data = load_data()
    
    if args:
        c = get_contact(data, args[0], "Change stage for which contact?")
        new_stage = args[1].lower() if len(args) > 1 else None
    else:
        c = get_contact(data, None, "Change stage for which contact?")
        new_stage = None
    
    if not c:
        return
    
    stages = get_stages(data)
    if not new_stage:
        new_stage = pick_one(stages, prompt=f"New stage for {c['name']} (current: {c['stage']})")
        if not new_stage:
            return

    if new_stage not in stages:
        print(f"Invalid stage. Use: {', '.join(stages)}")
        return
    
    old_stage = c["stage"]
    c["stage"] = new_stage
    
    stamp = datetime.now(get_tz(data)).strftime("%Y-%m-%d %H:%M")
    if "notes" not in c:
        c["notes"] = []
    c["notes"].insert(0, {"date": stamp, "text": f"Stage: {old_stage} → {new_stage}"})
    
    save_data(data)
    print(f"{c['name']}: {old_stage} → {new_stage}")

def cmd_next(args):
    data = load_data()
    
    if args:
        c = get_contact(data, args[0], "Set next action for which contact?")
        action = args[1] if len(args) > 1 else None
        date = args[2] if len(args) > 2 else None
    else:
        c = get_contact(data, None, "Set next action for which contact?")
        action = None
        date = None
    
    if not c:
        return
    
    if not action:
        action = input("Next action: ").strip()
        if not action:
            print("Cancelled.")
            return
    
    if not date:
        date = input("Due date (YYYY-MM-DD or +7d) [+7d]: ").strip() or "+7d"
    
    parsed = parse_date(date, get_tz(data))
    if parsed is None:
        return

    c["next_action"] = action
    c["next_date"] = parsed
    
    save_data(data)
    print(f"{c['name']}: next → {c['next_action']} ({c['next_date']})")

def cmd_due(args):
    data = load_data()
    tz = get_tz(data)
    days = int(args[0]) if args else 7
    cutoff = (datetime.now(tz) + timedelta(days=days)).strftime("%Y-%m-%d")
    today = datetime.now(tz).strftime("%Y-%m-%d")
    due = []
    overdue = []
    
    for c in data["contacts"]:
        next_date = c.get("next_date", "")
        if not next_date:
            continue
        if next_date < today:
            overdue.append(c)
        elif next_date <= cutoff:
            due.append(c)
    
    if overdue:
        print(f"\nOVERDUE ({len(overdue)})")
        for c in sorted(overdue, key=lambda x: x["next_date"]):
            print(format_contact_line(c))
    
    if due:
        print(f"\nDUE WITHIN {days} DAYS ({len(due)})")
        for c in sorted(due, key=lambda x: x["next_date"]):
            print(format_contact_line(c))
    
    if not due and not overdue:
        print(f"Nothing due within {days} days")
    print()

def cmd_add(args):
    if not args:
        print("Usage: crm add <contact|stage>")
        return
    if args[0] == "stage":
        return cmd_add_stage(args[1:])
    if args[0] != "contact":
        print(f"Unknown: crm add {args[0]}. Use: crm add <contact|stage>")
        return

    print("Add new contact:")
    name = input("  Name: ").strip()
    if not name:
        print("Cancelled.")
        return
    email = input("  Email: ").strip()
    if email and "@" not in email:
        print("  Invalid email.")
        return
    phone = input("  Phone: ").strip()
    company = input("  Company: ").strip()
    role = input("  Role: ").strip()
    source = input("  Source (cold/referral/inbound): ").strip() or "cold"
    
    data = load_data()

    dupes = [c for c in data["contacts"] if c["name"].lower() == name.lower()]
    if dupes:
        print(f"  Warning: '{dupes[0]['name']}' ({dupes[0].get('company', '')}) already exists.")
        confirm = input("  Continue anyway? [y/N] ").strip().lower()
        if confirm != 'y':
            print("Cancelled.")
            return

    stamp = datetime.now(get_tz(data)).strftime("%Y-%m-%d %H:%M")

    contact = {
        "name": name,
        "email": email,
        "phone": phone,
        "company": company,
        "role": role,
        "source": source,
        "stage": "cold",
        "next_action": "",
        "next_date": "",
        "notes": [{"date": stamp, "text": "Added to CRM"}]
    }
    
    data["contacts"].append(contact)
    save_data(data)
    print(f"Added {name}")

def cmd_edit(args):
    data = load_data()
    c = get_contact(data, args[0] if args else None, "Edit which contact?")
    if not c:
        return
    
    idx = data["contacts"].index(c)
    
    import tempfile
    import subprocess
    
    editor = os.environ.get("EDITOR", "nano")
    
    with tempfile.NamedTemporaryFile(mode="w", suffix=".json", delete=False, encoding="utf-8") as f:
        json.dump(c, f, indent=2, ensure_ascii=False)
        tmp_path = f.name
    
    try:
        subprocess.run([editor, tmp_path])
        with open(tmp_path, "r", encoding="utf-8") as f:
            updated = json.load(f)
        data["contacts"][idx] = updated
        save_data(data)
        print(f"Updated {updated['name']}")
    except Exception as e:
        print(f"Error: {e}")
    finally:
        os.unlink(tmp_path)

def cmd_rm(args):
    if not args:
        print("Usage: crm rm <contact|stage>")
        return
    if args[0] == "stage":
        return cmd_rm_stage(args[1:])
    if args[0] != "contact":
        print(f"Unknown: crm rm {args[0]}. Use: crm rm <contact|stage>")
        return

    data = load_data()
    c = get_contact(data, args[1] if len(args) > 1 else None, "Remove which contact?")
    if not c:
        return
    
    confirm = input(f"Remove {c['name']} ({c['company']})? [y/N] ").strip().lower()
    if confirm != 'y':
        print("Cancelled.")
        return
    
    data["contacts"].remove(c)
    stamp = datetime.now(get_tz(data)).strftime("%Y-%m-%d %H:%M")
    c["removed_at"] = stamp
    data["removed"].append(c)
    save_data(data)
    print(f"Removed {c['name']}")

def cmd_restore(args):
    data = load_data()
    removed = data.get("removed", [])
    if not removed:
        print("No removed contacts.")
        return

    if args:
        query = args[0].lower()
        matches = [c for c in removed if query in c["name"].lower() or query in c["company"].lower()]
    else:
        matches = removed

    if not matches:
        print(f"No removed contacts matching '{args[0]}'")
        return

    def format_removed(c):
        return f"{c['name']} ({c['company']}) [removed {c.get('removed_at', '?')}]"

    if len(matches) == 1:
        c = matches[0]
    else:
        c = pick_one(matches, prompt="Restore which contact?", format_fn=format_removed)

    if not c:
        return

    dupes = [x for x in data["contacts"] if x["name"].lower() == c["name"].lower() and x["company"].lower() == c["company"].lower()]
    if dupes:
        print(f"{c['name']} ({c['company']}) already exists in contacts.")
        return

    data["removed"].remove(c)
    del c["removed_at"]
    data["contacts"].append(c)
    save_data(data)
    print(f"Restored {c['name']} ({c['company']})")

def cmd_config(args):
    data = load_data()

    cfg = data["config"]

    if not args:
        if not cfg:
            print("No config set.")
            return
        for k, v in cfg.items():
            print(f"  {k} = {v}")
        return

    key = args[0]

    if len(args) == 1:
        if key in cfg:
            print(f"  {key} = {cfg[key]}")
        else:
            print(f"  {key} not set")
        return

    # Set
    value = " ".join(args[1:])

    if key == "timezone":
        try:
            _parse_tz(value)
        except (ValueError, IndexError):
            print(f"Invalid timezone: {value}. Use format like UTC+03:00")
            return

    cfg[key] = value
    data["config"] = cfg
    save_data(data)
    print(f"  {key} = {value}")

def cmd_stages(args):
    data = load_data()
    stages = get_stages(data)
    print("Stages:")
    for s in stages:
        print(f"  {s}")

def cmd_add_stage(args):
    if not args:
        print("Usage: crm add stage <name>")
        return
    data = load_data()
    stages = get_stages(data)
    name = args[0].lower()
    if name in stages:
        print(f"Stage '{name}' already exists.")
        return
    stages.append(name)
    save_data(data)
    print(f"Added stage: {name}")

def cmd_rm_stage(args):
    if not args:
        print("Usage: crm rm stage <name>")
        return
    data = load_data()
    stages = get_stages(data)
    name = args[0].lower()
    if name not in stages:
        print(f"Stage '{name}' not found.")
        return
    in_use = [c for c in data["contacts"] if c["stage"] == name]
    if in_use:
        print(f"Can't remove '{name}' — {len(in_use)} contact(s) in this stage.")
        return
    stages.remove(name)
    save_data(data)
    print(f"Removed stage: {name}")

def cmd_search(args):
    if not args:
        term = input("Search: ").strip()
        if not term:
            print("Cancelled.")
            return
    else:
        term = " ".join(args)
    
    term = term.lower()
    data = load_data()
    results = []
    
    for c in data["contacts"]:
        matches = []
        
        # Search fields
        for field in ["name", "company", "email", "phone", "role", "source", "next_action"]:
            if term in c.get(field, "").lower():
                matches.append(f"{field}: {c.get(field)}")
        
        # Search notes
        for note in c.get("notes", []):
            if term in note["text"].lower():
                matches.append(f"[{note['date']}] {note['text'][:60]}...")
        
        if matches:
            results.append((c, matches))
    
    if not results:
        print(f"No results for '{term}'")
        return
    
    print(f"\nFound {len(results)} contact(s):\n")
    for c, matches in results:
        print(f"{c['name']} ({c['company']}) [{c['stage'].upper()}]")
        for m in matches[:3]:  # Show max 3 matches per contact
            print(f"    → {m}")
        if len(matches) > 3:
            print(f"    → ...and {len(matches) - 3} more")
        print()

def main():
    if len(sys.argv) < 2:
        print(__doc__)
        return
    
    cmd = sys.argv[1]
    args = sys.argv[2:]
    
    commands = {
        "list": cmd_list,
        "ls": cmd_list,
        "show": cmd_show,
        "note": cmd_note,
        "stage": cmd_stage,
        "next": cmd_next,
        "due": cmd_due,
        "add": cmd_add,
        "edit": cmd_edit,
        "rm": cmd_rm,
        "remove": cmd_rm,
        "restore": cmd_restore,
        "search": cmd_search,
        "find": cmd_search,
        "stages": cmd_stages,
        "config": cmd_config,
        "cfg": cmd_config,
    }
    
    if cmd in commands:
        commands[cmd](args)
    else:
        print(f"Unknown command: {cmd}")
        print(__doc__)

if __name__ == "__main__":
    main()
